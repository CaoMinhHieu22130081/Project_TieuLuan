# Sao chép file này thành .env và điền giá trị thật khi deploy lên server

# URL gốc của Backend API (không có dấu / ở cuối)
# Mặc định khi chạy local: http://localhost:8080/api
VITE_API_URL=http://localhost:8080/api

# URL WebSocket (cho tính năng chat real-time)
# Mặc định khi chạy local: http://localhost:8080/api/ws
VITE_WS_URL=http://localhost:8080/api/ws
